# Caminho do banco SQLite (em produção, use caminho absoluto ou volume persistente)
# Exemplo Railway: /data/app.db
DATABASE_URL=/data/app.db

# Chave secreta para assinar os JWTs de autenticação (gere uma string longa e aleatória)
JWT_SECRET=troque-por-uma-chave-secreta-muito-longa-e-aleatoria

# Token secreto para validar webhooks recebidos da Kirvano
KIRVANO_WEBHOOK_TOKEN=troque-pelo-token-do-webhook-kirvano

# Porta em que o servidor irá escutar (Railway injeta automaticamente)
PORT=3000
